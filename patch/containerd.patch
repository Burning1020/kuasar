+// Sandboxes returns all sandboxes created in containerd
+func (c *Client) Sandboxes(ctx context.Context, filters ...string) ([]Sandbox, error) {
+	r, err := c.SandboxStore().List(ctx, filters...)
+	if err != nil {
+		return nil, err
+	}
+	var out []Sandbox
+	for _, s := range r {
+		out = append(out, sandboxFromRecord(c, s))
+	}
+	return out, nil
+}
