+	Terminal   bool
+}
+
+func (h *VsockSet) config() cio.Config {
+	return cio.Config{
+		Terminal: h.Terminal,
+		Stdin:    portToStd(h.sockType, h.sockAddr, h.stdinPort),
+		Stdout:   portToStd(h.sockType, h.sockAddr, h.stdoutPort),
+		Stderr:   portToStd(h.sockType, h.sockAddr, h.stderrPort),
